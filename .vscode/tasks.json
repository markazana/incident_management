{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill-cds-processes",
      "type": "shell",
      "command": "pids=$(ps aux | grep -vE 'grep|bash' | grep 'cds.js' | awk '{print $2}'); if [ -n \"$pids\" ]; then kill $pids; fi",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "npm-install",
      "type": "process",
      "command": "npm",
      "args": [
        "install"
      ],
      "dependsOn": [
        "kill-cds-processes"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "BuildMDK",
      "type": "shell",
      "command": "if npm list @sap/mdk-tools --depth=0 > /dev/null 2>&1; then npx mdk build --target module --ui5 --recursive;fi",
      "dependsOn": [
        "npm-install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "dev-project-cap",
      "type": "process",
      "command": "npx",
      "args": [
        "node",
        "-e",
        "console.log(\"prelaunch task returns OK\")"
      ],
      "dependsOn": [
        "npm-install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "PreLaunchTask for Run Incidents with Dummy Authentication",
      "type": "process",
      "command": "npx",
      "args": [
        "node",
        "-e",
        "console.log(\"prelaunch task returns OK\")"
      ],
      "dependsOn": [
        "npm-install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "type": "build.mta",
      "label": "Build ",
      "taskType": "Build",
      "projectPath": "/home/user/projects/incident_management",
      "extensions": []
    },
    {
      "type": "deploy.mta.cf",
      "label": "Deploy to Cloud Foundry ",
      "taskType": "Deploy",
      "mtarPath": "/home/user/projects/incident_management/mta_archives/incident_management_1.0.0.mtar",
      "extensions": [],
      "dependsOn": [
        "Build "
      ],
      "cfTarget": "b19f2ac7trial_ttq068bskvv8s258",
      "cfEndpoint": "https://api.cf.us10-001.hana.ondemand.com",
      "cfOrg": "b19f2ac7trial_ttq068bskvv8s258",
      "cfSpace": "incident_management"
    }
  ]
}